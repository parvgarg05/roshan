# Roshanlal & Sons – Environment Variables
# Copy this to .env.local and fill in real values

# ─── Database (Neon / Supabase / any Postgres) ──────────────────────────────
# Use a pooled/transaction URL in production serverless (PgBouncer / Neon pooler / Prisma Accelerate)
DATABASE_URL="postgresql://user:password@your-pooler-host/dbname?sslmode=require"

# Optional but recommended for Prisma migrations/introspection (direct non-pooled connection)
# DIRECT_URL="postgresql://user:password@your-direct-host:5432/dbname?sslmode=require"

# ─── Razorpay (get from dashboard.razorpay.com → Test Mode → API Keys) ──────
# Server-side only (NEVER expose directly)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# Public key (safe to expose to client – used to open the payment widget)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"

# ─── App / Admin Auth ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-admin-password"
JWT_SECRET="change-this-jwt-secret"

# ─── Email (Nodemailer / Resend / SendGrid / Gmail) ─────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="apikey"
SMTP_PASS="your-password"
FROM_EMAIL="orders@roshanlal.com"
ADMIN_EMAIL="admin@roshanlal.com"

